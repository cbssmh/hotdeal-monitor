# Required for Discord notifications.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token

# Used by the legacy local APScheduler entrypoint. app.py itself is one-shot.
CHECK_INTERVAL_MINUTES=10

# Site enable/disable settings are configured in sites.json.
# FMKorea is implemented but disabled by default because cloud/server networks
# can receive HTTP 430 responses from that site.
